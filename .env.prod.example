# HotKey 生产 / 自托管环境变量示例
# 复制为 .env.prod 后替换所有占位符；不要把真实 .env.prod 提交到仓库。
#
# 启动：
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# =============================================================================
# 1. 应用基础
# =============================================================================

APP_ENV=production
APP_NAME=hotkey-server
APP_TIMEZONE=Asia/Shanghai
APP_SECRET_KEY=replace-with-strong-random-secret

WEB_PUBLISHED_PORT=8080
WEB_FRONTEND_PORT=3000

# 浏览器访问 API / Web 的公网或局域网地址（用于前端构建与 n8n 回调）
PUBLIC_API_URL=http://127.0.0.1:8080
PUBLIC_WEB_URL=http://127.0.0.1:3000
WEB_BASE_URL=http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000

# =============================================================================
# 2. PostgreSQL（由 docker-compose.prod.yml 容器提供）
# =============================================================================

POSTGRES_USER=hotkey
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=hotkey

# server 容器内由 compose 覆写为 postgres:5432；此处保留供排查或外部工具使用
HOTKEY_DATABASE_URL=postgres://hotkey:replace-with-strong-postgres-password@postgres:5432/hotkey?sslmode=disable

PGVECTOR_REQUIRED=true
EMBEDDING_DIMENSION=1536

# =============================================================================
# 3. Redis（由 docker-compose.prod.yml 容器提供）
# =============================================================================

REDIS_DB=0
HOTKEY_REDIS_URL=redis://redis:6379/0

# =============================================================================
# 4. AI / DashScope
# =============================================================================

HOTKEY_DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
HOTKEY_EMBEDDING_MODEL=text-embedding-v2

# =============================================================================
# 5. 认证与安全
# =============================================================================

HOTKEY_AUTH_TOKEN_SECRET=replace-with-strong-jwt-secret
HOTKEY_ENCRYPTION_KEY=replace-with-32-byte-encryption-key
HOTKEY_INTERNAL_API_KEY=replace-with-strong-internal-key
HOTKEY_DEFAULT_TENANT_ID=tenant-default

# =============================================================================
# 6. MinIO（由 docker-compose.prod.yml 容器提供）
# =============================================================================

HOTKEY_MINIO_ENDPOINT=minio:9000
HOTKEY_MINIO_ACCESS_KEY=replace-with-strong-minio-access-key
HOTKEY_MINIO_SECRET_KEY=replace-with-strong-minio-secret-key
HOTKEY_MINIO_BUCKET=hotkey-snapshots
HOTKEY_MINIO_USE_SSL=false
HOTKEY_MINIO_LOCATION=us-east-1
HOTKEY_CONTENT_RETENTION_DAYS=30

# =============================================================================
# 7. SMTP（可选，日报邮件）
# =============================================================================

HOTKEY_SMTP_HOST=smtp.example.com
HOTKEY_SMTP_PORT=587
HOTKEY_SMTP_USERNAME=replace-with-smtp-user
HOTKEY_SMTP_PASSWORD=replace-with-smtp-password
HOTKEY_SMTP_FROM=HotKey <no-reply@example.com>
HOTKEY_SMTP_TLS=false
HOTKEY_SMTP_STARTTLS=true

# =============================================================================
# 8. n8n 自动化（由 docker-compose.prod.yml 容器提供）
# =============================================================================

N8N_PUBLISHED_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://127.0.0.1:5678
N8N_ENCRYPTION_KEY=replace-with-strong-n8n-encryption-key
N8N_BASE_URL=http://127.0.0.1:5678

# n8n workflow 调用 HotKey Internal API 时，在 prod compose 网络内使用：
#   http://server:8080/api/v1/internal/...

# =============================================================================
# 9. X 平台 OAuth（按需填写）
# =============================================================================

HOTKEY_X_CLIENT_ID=
HOTKEY_X_CLIENT_SECRET=
HOTKEY_X_REDIRECT_URL=http://127.0.0.1:8080/api/v1/admin/x/auth/callback

# =============================================================================
# 10. 可观测性
# =============================================================================

LOG_LEVEL=info
LOG_FORMAT=json
PPROF_ENABLED=false
