    "definitions": {
        "http.AuthenticationResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string",
                    "example": "signed-access-token"
                },
                "user": {
                    "$ref": "#/definitions/http.UserResponse"
                }
            }
        },
        "http.Capabilities": {
            "type": "object",
            "properties": {
                "api_version": {
                    "type": "string"
                }
            }
        },
        "http.ChangePasswordRequest": {
            "type": "object",
            "required": [
                "current_password",
                "new_password"
            ],
            "properties": {
                "current_password": {
                    "type": "string"
                },
                "new_password": {
                    "type": "string"
                }
            }
        },
        "http.ConfirmPasswordResetRequest": {
            "type": "object",
            "required": [
                "password",
                "verification_ticket"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "verification_ticket": {
                    "type": "string"
                }
            }
        },
        "http.ConfirmVerificationRequest": {
            "type": "object",
            "required": [
                "code",
                "email",
                "purpose"
            ],
            "properties": {
                "code": {
                    "type": "string",
                    "example": "123456"
                },
                "email": {
                    "type": "string",
                    "example": "reader@example.test"
                },
                "purpose": {
                    "type": "string",
                    "enum": [
                        "registration",
                        "password_reset"
                    ],
                    "example": "registration"
                }
            }
        },
        "http.ConfirmVerificationResponse": {
            "type": "object",
            "properties": {
                "verification_ticket": {
                    "type": "string",
                    "example": "opaque-single-use-ticket"
                }
            }
        },
        "http.EmptyResponse": {
            "type": "object"
        },
        "http.IdentityResult-array_http_UserResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/http.UserResponse"
                    }
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "http.IdentityResult-http_AuthenticationResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/http.AuthenticationResponse"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "http.IdentityResult-http_ConfirmVerificationResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/http.ConfirmVerificationResponse"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "http.IdentityResult-http_EmptyResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/http.EmptyResponse"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "http.IdentityResult-http_UserResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/http.UserResponse"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "http.LoginRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "reader@example.test"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "http.RegistrationRequest": {
            "type": "object",
            "required": [
                "display_name",
                "password",
                "verification_ticket"
            ],
            "properties": {
                "display_name": {
                    "type": "string",
                    "example": "Reader"
                },
                "password": {
                    "type": "string"
                },
                "verification_ticket": {
                    "type": "string"
                }
            }
        },
        "http.RequestVerificationRequest": {
            "type": "object",
            "required": [
                "email",
                "purpose"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "reader@example.test"
                },
                "purpose": {
                    "type": "string",
                    "enum": [
                        "registration",
                        "password_reset"
                    ],
                    "example": "registration"
                }
            }
        },
        "http.Result-http_Capabilities": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/http.Capabilities"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "http.UpdateUserRequest": {
            "type": "object",
            "properties": {
                "role": {
                    "type": "string",
                    "enum": [
                        "admin",
                        "editor",
                        "viewer"
                    ]
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "disabled"
                    ]
                }
            }
        },
        "http.UserResponse": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "type": "string"
                },
                "display_name": {
                    "type": "string",
                    "example": "Reader"
                },
                "email": {
                    "type": "string",
                    "example": "reader@example.test"
                },
                "id": {
                    "type": "integer",
                    "example": 3
                },
                "last_login_at": {
                    "type": "string"
                },
                "role": {
                    "type": "string",
                    "enum": [
                        "admin",
                        "editor",
                        "viewer"
                    ]
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "disabled"
                    ]
                },
                "updated_at": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Use a database-backed access token as `Bearer {access_token}`.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}