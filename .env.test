# HotKey Server 测试环境配置
# 用于自动化测试和 CI 环境；不含真实凭证。

# =============================================================================
# 1. 应用基础
# =============================================================================
HOTKEY_APP_ENV=test
HOTKEY_APP_NAME=hotkey-server-test
HOTKEY_APP_TIMEZONE=Asia/Shanghai
HOTKEY_HTTP_ADDR=:8080

# =============================================================================
# 2. PostgreSQL / pgvector
# =============================================================================
HOTKEY_DATABASE_URL=postgres://hotkey:hotkey@localhost:5432/hotkey?sslmode=disable

# =============================================================================
# 3. Redis
# =============================================================================
HOTKEY_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 4. DashScope
# =============================================================================
HOTKEY_DASHSCOPE_API_KEY=test-dashscope-key
HOTKEY_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
HOTKEY_DASHSCOPE_CHAT_MODEL=qwen-plus
HOTKEY_EMBEDDING_MODEL=text-embedding-v2

# =============================================================================
# 5. SMTP（测试用占位）
# =============================================================================
HOTKEY_SMTP_HOST=smtp.test.com
HOTKEY_SMTP_PORT=587
HOTKEY_SMTP_USERNAME=test-user
HOTKEY_SMTP_PASSWORD=test-password
HOTKEY_SMTP_FROM=HotKey Test <test@test.com>

# =============================================================================
# 6. MinIO（测试用占位）
# =============================================================================
HOTKEY_MINIO_ENDPOINT=localhost:9000
HOTKEY_MINIO_ACCESS_KEY=minioadmin
HOTKEY_MINIO_SECRET_KEY=minioadmin
HOTKEY_MINIO_BUCKET=hotkey-snapshots-test

# =============================================================================
# 7. X 平台 OAuth（测试用占位）
# =============================================================================
HOTKEY_X_CLIENT_ID=test-x-client-id
HOTKEY_X_CLIENT_SECRET=test-x-client-secret
HOTKEY_X_REDIRECT_URL=http://localhost:8080/api/v1/admin/x/auth/callback

# =============================================================================
# 8. 日志与可观测性
# =============================================================================
HOTKEY_LOG_LEVEL=debug
HOTKEY_LOG_FORMAT=text
