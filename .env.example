# HotKey Server 环境变量示例
# 复制本文件为本地 `.env` 后再填写真实值；不要把真实 `.env` 提交到仓库。

# =============================================================================
# 1. 应用基础配置
# =============================================================================

# 当前运行环境：local、development、test、staging、production
APP_ENV=local

# 应用名称，用于日志、OpenAPI、监控和 n8n 回调标识
APP_NAME=hotkey-server

# 默认时区，日报生成和调度窗口会使用该值
APP_TIMEZONE=Asia/Shanghai

# 应用级密钥占位，用于未来签名、加密或会话派生；生产环境必须替换为强随机值
APP_SECRET_KEY=change-me

# Go HTTP 服务监听地址；当前代码读取 HOTKEY_HTTP_ADDR
HOTKEY_HTTP_ADDR=:8080

# 兼容旧变量：如果后续接入统一配置加载，可映射到 HOTKEY_HTTP_ADDR
APP_HOST=0.0.0.0
APP_PORT=8080
API_HOST=0.0.0.0
API_PORT=8080

# 对外发布端口，通常用于 Docker Compose 或反向代理
WEB_PUBLISHED_PORT=8080

# =============================================================================
# 2. PostgreSQL / pgvector
# =============================================================================

# 当前代码读取 HOTKEY_DATABASE_URL
HOTKEY_DATABASE_URL=postgres://hotkey:hotkey@localhost:5432/hotkey?sslmode=disable

# 兼容旧变量：保留给 Docker Compose、脚本或未来配置加载器使用
DATABASE_URL=postgres://hotkey:hotkey@localhost:5432/hotkey?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hotkey
POSTGRES_USER=hotkey
POSTGRES_PASSWORD=hotkey

# 是否在启动或部署时检查 pgvector 扩展
PGVECTOR_REQUIRED=true

# 首期 embedding 维度；必须与 db/schema.sql 中 vector(1536) 保持一致
EMBEDDING_DIMENSION=1536

# =============================================================================
# 3. Redis
# =============================================================================

# 当前代码读取 HOTKEY_REDIS_URL
HOTKEY_REDIS_URL=redis://localhost:6379/0

# 兼容旧变量
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Redis 用途开关：任务锁、限流、热点缓存、短期去重、刷新队列
REDIS_TASK_LOCK_ENABLED=true
REDIS_RATE_LIMIT_ENABLED=true
REDIS_HOTSPOT_CACHE_TTL_SECONDS=300
REDIS_DEDUPE_TTL_SECONDS=86400

# =============================================================================
# 4. AI / Embedding / LLM (阿里云灵积 DashScope)
# =============================================================================

# 阿里云灵积 DashScope API 配置；使用 OpenAI 兼容接口模式
# 申请地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 聊天/总结模型，用于日报、事件摘要和审核辅助
# 推荐：qwen-plus（平衡）、qwen-turbo（快速）、qwen-max（最强）
DASHSCOPE_CHAT_MODEL=qwen-plus

# 向量模型，用于内容向量和事件向量
# text-embedding-v2（1536 维，兼容现有 schema）、text-embedding-v3（1024 维）
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# AI 失败策略：fallback 表示降级，fail 表示直接失败，skip 表示跳过 AI 增强
AI_PROVIDER_ERROR_STRATEGY=fallback
AI_FALLBACK_PROVIDER=

# =============================================================================
# 5. 热点采集、相似度和调度
# =============================================================================

# 单来源每轮最大采集条数
SOURCE_FETCH_LIMIT=50

# 事实源默认轮询间隔；用于官网、论文、官方发布等可靠来源
FACT_SOURCE_INTERVAL_MINUTES=60

# 传播源默认轮询间隔；用于社区、视频、社交和技术媒体等传播来源
SIGNAL_SOURCE_INTERVAL_MINUTES=30

# 内容与事件归并的相似度阈值；最终阈值以后端 similarity_rules 为准
RELEVANCE_THRESHOLD=0.82

# 是否启用后端调度器；n8n 外部编排模式下可按需关闭
SCHEDULER_ENABLED=false

# 每分钟基础限流值
RATE_LIMIT_PER_MINUTE=120

# =============================================================================
# 6. Internal API / n8n 自动化编排
# =============================================================================

# n8n 访问 hotkey-server internal API 的共享密钥；生产环境必须替换为强随机值
HOTKEY_INTERNAL_API_KEY=replace-with-strong-internal-key

# 默认租户 ID，占位给 n8n 本地调试使用；生产环境建议由 n8n workflow 明确传入
HOTKEY_DEFAULT_TENANT_ID=tenant-default

# n8n 实例地址，仅用于回调、日志定位和后续 API 管理
N8N_BASE_URL=http://localhost:5678

# n8n API Key 只用于后端需要管理 workflow 时；第一阶段可留空
N8N_API_KEY=

# n8n workflow 名称约定
N8N_DAILY_REPORT_WORKFLOW=daily_ai_hotspot_email_digest
N8N_FACT_SOURCE_WORKFLOW=fact_source_collector
N8N_SIGNAL_SOURCE_WORKFLOW=signal_source_collector
N8N_REVIEW_WORKFLOW=event_review_notification

# =============================================================================
# 7. SMTP 日报邮件
# =============================================================================

# SMTP 凭证建议优先放在 n8n Credentials 中；这些变量仅作为自托管/本地调试占位
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=HotKey <no-reply@example.com>

# 多个收件人使用英文逗号分隔
DAILY_REPORT_RECIPIENTS=admin@example.com

# 日报发送时间和默认时区
DAILY_REPORT_SEND_TIME=08:30
DAILY_REPORT_TIMEZONE=Asia/Shanghai

# =============================================================================
# 8. Web / 小程序 / 前端
# =============================================================================

# 小程序或前端访问后端 API 的基础地址
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# 管理后台或官网地址，用于邮件链接、回调和跨域配置
WEB_BASE_URL=http://localhost:3000

# 允许的跨域来源，多个来源用英文逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# 9. 认证与会话
# =============================================================================

# JWT 密钥；生产环境必须替换为强随机值
JWT_SECRET_KEY=replace-with-strong-jwt-secret

# 会话过期天数
JWT_SESSION_EXPIRE_DAYS=7

# =============================================================================
# 10. 可观测性与日志
# =============================================================================

# 日志级别：debug、info、warn、error
LOG_LEVEL=info

# 日志格式：text、json
LOG_FORMAT=text

# 是否启用 pprof；生产环境默认关闭
PPROF_ENABLED=false

# OpenTelemetry endpoint，占位给后续链路追踪使用
OTEL_EXPORTER_OTLP_ENDPOINT=
