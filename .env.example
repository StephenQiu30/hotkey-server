# =============================================================================
# hotkey-server 环境变量模板
# 使用: cp .env.example .env 后按本地环境修改
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=hotkey
POSTGRES_PASSWORD=hotkey
POSTGRES_DB=hotkey
# 本地 go run / psql 直连（宿主机端口 5432）
DATABASE_URL=postgres://hotkey:hotkey@localhost:5432/hotkey?sslmode=disable
# 设为 1 时禁用 API/Worker 启动时的自动建库与 schema 初始化
# DB_SKIP_INIT=1

# --- API / Worker（必填）---
HTTP_ADDR=:8080
JWT_SECRET=dev-local-jwt-secret-change-in-production

# --- Obsidian / 日报（日报功能启用时填写）---
# Vault 同步目录根路径（日报功能必填）
# OBSIDIAN_VAULT_PATH=/path/to/obsidian/vault
# CST 触发时刻（默认 08:00）
# DAILY_DIGEST_TIME=08:00
# 时区（默认 Asia/Shanghai）
# DAILY_DIGEST_TIMEZONE=Asia/Shanghai
# 导出日目标：yesterday 或 today（默认 yesterday）
# DAILY_DIGEST_TARGET=yesterday
# 每 monitor 最多导出主题数（默认 20）
# DAILY_DIGEST_TOP_N=20

# --- X/Twitter API（热点采集必填）---
X_BEARER_TOKEN=

# --- LLM（日报摘要启用时填写）---
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Symphony / Linear（可选，仅 Symphony 调度需要）---
# Linear 个人 API Key；如果你已经在 shell 全局 export 了 LINEAR_API_KEY，这里可以留空。
LINEAR_API_KEY=
# Symphony 要轮询的 Linear 项目 slug；从 Linear 项目 URL 中复制最后的 slug 部分。
SYMPHONY_LINEAR_PROJECT_SLUG=
# Symphony 在本机创建每个任务工作区的根目录。
SYMPHONY_WORKSPACE_ROOT=/Users/stephenqiu/Desktop/StephenQiu30/Agents/symphony/workspaces
# 每个 Linear 任务创建 workspace 后要 clone 的目标代码仓库地址；私有仓库推荐使用 SSH 地址。
SOURCE_REPO_URL=https://github.com/StephenQiu30/hotkey-server
# Dashboard 映射到宿主机的端口。
SYMPHONY_PORT=4000
# Docker 启动时，宿主机上用于保存 workspace 的目录。
SYMPHONY_HOST_WORKSPACE_ROOT=./.symphony-workspaces
