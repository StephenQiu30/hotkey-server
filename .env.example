# Runtime: development, testing, production
HOTKEY_ENV=development
HOTKEY_ROLE=all
HOTKEY_HTTP_ADDR=:8080
HOTKEY_REQUEST_TIMEOUT=15s
HOTKEY_SHUTDOWN_TIMEOUT=15s

# Optional OTLP/HTTP trace exporter endpoint, for example http://localhost:4318/v1/traces.
HOTKEY_OTLP_HTTP_ENDPOINT=

# PostgreSQL is the business fact store and River job store.
HOTKEY_DATABASE_URL=postgres://hotkey:hotkey@localhost:5432/hotkey?sslmode=disable

# MinIO stores raw responses, extracted bodies, screenshots and attachments.
HOTKEY_MINIO_ENDPOINT=localhost:9000
HOTKEY_MINIO_ACCESS_KEY=hotkey
HOTKEY_MINIO_SECRET_KEY=change-me
HOTKEY_MINIO_BUCKET=hotkey-evidence
HOTKEY_MINIO_USE_SSL=false

# Local Obsidian vault root. The process may only write below this path.
HOTKEY_VAULT_PATH=./var/vault

# Authentication. Replace in every non-development environment.
HOTKEY_JWT_SECRET=change-me-with-at-least-32-characters

# Optional SMTP delivery.
HOTKEY_SMTP_ENABLED=false
HOTKEY_SMTP_HOST=
HOTKEY_SMTP_PORT=587
HOTKEY_SMTP_USERNAME=
HOTKEY_SMTP_PASSWORD=
HOTKEY_SMTP_FROM_EMAIL=
HOTKEY_SMTP_FROM_NAME=HotKey

# Optional source and AI credentials are enabled per source/profile.
HOTKEY_X_BEARER_TOKEN=
HOTKEY_YOUTUBE_API_KEY=
HOTKEY_REDDIT_CLIENT_ID=
HOTKEY_REDDIT_CLIENT_SECRET=
HOTKEY_LLM_API_KEY=
HOTKEY_LLM_BASE_URL=
HOTKEY_LLM_MODEL=
