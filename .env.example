# HotKey Server 环境变量示例
#
# 配置加载顺序：默认值 → .env 文件 → 系统环境变量（系统环境变量优先级最高）。
# 复制本文件为 `.env` 后再填写真实值；不要把真实 `.env` 提交到仓库。
# 测试环境请使用 `.env.test`。

# =============================================================================
# 1. 应用基础配置
# =============================================================================

# 当前运行环境：local / development / test / staging / production
HOTKEY_APP_ENV=local

# 应用名称，用于日志、OpenAPI、监控标识
HOTKEY_APP_NAME=hotkey-server

# 默认时区，日报生成和调度窗口会使用该值
HOTKEY_APP_TIMEZONE=Asia/Shanghai

# 应用级密钥占位，用于未来签名、加密或会话派生；生产环境必须替换为强随机值
HOTKEY_APP_SECRET_KEY=change-me

# Go HTTP 服务监听地址
HOTKEY_HTTP_ADDR=:8080

# =============================================================================
# 2. PostgreSQL / pgvector（必填）
# =============================================================================

# 数据库连接串；缺失时启动校验会报错
HOTKEY_DATABASE_URL=postgres://hotkey:hotkey@localhost:5432/hotkey?sslmode=disable

# =============================================================================
# 3. Redis（必填）
# =============================================================================

# Redis 连接串；缺失时启动校验会报错
HOTKEY_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 4. 认证与会话
# =============================================================================

# JWT 密钥；生产环境必须替换为强随机值
HOTKEY_JWT_SECRET_KEY=replace-with-strong-jwt-secret

# 会话过期天数（默认 7）
HOTKEY_JWT_SESSION_EXPIRE_DAYS=7

# HMAC 签名密钥；生产环境必须替换为强随机值
HOTKEY_AUTH_TOKEN_SECRET=

# 访问令牌有效期（Go duration 格式，默认 15m）
HOTKEY_AUTH_ACCESS_TOKEN_TTL=15m

# 刷新令牌有效期（Go duration 格式，默认 720h = 30天）
HOTKEY_AUTH_REFRESH_TOKEN_TTL=720h

# =============================================================================
# 5. AI / Embedding / LLM — 阿里云灵积 DashScope（可选）
# =============================================================================
# 未配置时 Capabilities().DashScopeEnabled = false

# DashScope API 密钥；申请地址：https://dashscope.console.aliyun.com/
HOTKEY_DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key

# DashScope OpenAI 兼容接口地址
HOTKEY_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 聊天/总结模型（推荐：qwen-plus / qwen-turbo / qwen-max）
HOTKEY_DASHSCOPE_CHAT_MODEL=qwen-plus

# 向量模型（text-embedding-v2 1536 维，兼容现有 schema）
HOTKEY_EMBEDDING_MODEL=text-embedding-v2

# 内容与事件归并的相似度阈值（默认 0.82）
HOTKEY_HOTSPOT_SIMILARITY_THRESHOLD=0.82

# 热点窗口时长（Go duration 格式，默认 24h）
HOTKEY_HOTSPOT_WINDOW=24h

# =============================================================================
# 6. SMTP 日报邮件（可选）
# =============================================================================
# 未配置 HOTKEY_SMTP_HOST 时 Capabilities().SMTPEnabled = false

HOTKEY_SMTP_HOST=smtp.example.com
HOTKEY_SMTP_PORT=587
HOTKEY_SMTP_USERNAME=replace-with-smtp-user
HOTKEY_SMTP_PASSWORD=replace-with-smtp-password
HOTKEY_SMTP_FROM=HotKey <no-reply@example.com>
HOTKEY_SMTP_TLS=false
HOTKEY_SMTP_STARTTLS=true

# =============================================================================
# 7. X 平台 OAuth（可选）
# =============================================================================
# 未配置 HOTKEY_X_CLIENT_ID 时 Capabilities().XEnabled = false

# X API v2 OAuth 2.0 + PKCE 配置；申请地址：https://developer.x.com/en/portal/dashboard
HOTKEY_X_CLIENT_ID=replace-with-x-client-id
HOTKEY_X_CLIENT_SECRET=replace-with-x-client-secret
HOTKEY_X_REDIRECT_URL=http://localhost:8080/api/v1/admin/x/auth/callback

# =============================================================================
# 8. MinIO 对象存储（可选）
# =============================================================================
# 未配置 HOTKEY_MINIO_ACCESS_KEY 时 Capabilities().MinIOEnabled = false

HOTKEY_MINIO_ENDPOINT=localhost:9000
HOTKEY_MINIO_ACCESS_KEY=minioadmin
HOTKEY_MINIO_SECRET_KEY=minioadmin
HOTKEY_MINIO_BUCKET=hotkey-snapshots
HOTKEY_MINIO_USE_SSL=false
HOTKEY_MINIO_LOCATION=us-east-1

# 原始快照默认留存天数（0 表示立即删除，默认 30）
HOTKEY_CONTENT_RETENTION_DAYS=30

# =============================================================================
# 9. 运行模式与调度
# =============================================================================

# 运行模式：all / api / worker（默认 all）
HOTKEY_RUNTIME_MODE=all

# 采集来源 ID
HOTKEY_COLLECT_SOURCE_ID=default

# 是否启用后端调度器（默认 false，n8n 外部编排模式下可按需关闭）
HOTKEY_SCHEDULER_ENABLED=false

# =============================================================================
# 10. 日志与可观测性
# =============================================================================

# 日志级别：debug / info / warn / error（默认 info）
HOTKEY_LOG_LEVEL=info

# 日志格式：text / json（默认 text）
HOTKEY_LOG_FORMAT=text

# 是否启用 pprof（默认 false）
HOTKEY_PPROF_ENABLED=false

# OpenTelemetry endpoint（留空表示不启用）
HOTKEY_OTEL_EXPORTER_OTLP_ENDPOINT=

# =============================================================================
# 11. 加密
# =============================================================================

# 加密密钥；留空表示不启用加密
HOTKEY_ENCRYPTION_KEY=
