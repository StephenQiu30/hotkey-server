# Production environment
APP_ENV=production
APP_NAME=ai-hotspot-radar
APP_TIMEZONE=Asia/Shanghai
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL（生产环境）
DATABASE_URL=postgresql+psycopg://ai_user:change-me@postgres:5432/ai_hotspot_radar
DATABASE_INIT_RETRIES=20
DATABASE_INIT_RETRY_SECONDS=2
REDIS_URL=redis://redis:6379/0

# AI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
RELEVANCE_THRESHOLD=55
SOURCE_FETCH_LIMIT=30
RATE_LIMIT_PER_MINUTE=600

# Optional X/Twitter source
X_API_BEARER_TOKEN=

# Optional Bing source
BING_SEARCH_API_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAIL=
SMTP_USE_TLS=true

# Scheduler
SCHEDULER_ENABLED=true
CHECK_INTERVAL_MINUTES=15
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR=8
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_WEEKDAY=1
WEEKLY_REPORT_HOUR=8

# Web
NEXT_PUBLIC_API_BASE_URL=/

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-domain.com/api/auth/github/callback
WEB_BASE_URL=https://your-domain.com

# JWT
JWT_SECRET_KEY=change-me-production-secret-key
JWT_SESSION_EXPIRE_DAYS=7
OAUTH_STATE_TTL_SECONDS=300
