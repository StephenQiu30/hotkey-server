# Application
APP_ENV=development
APP_NAME=ai-hotspot-radar
APP_TIMEZONE=Asia/Shanghai
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
# 必填：本机 PostgreSQL 连接串
DATABASE_URL=postgresql+psycopg://<数据库用户>:<数据库密码>@localhost:5432/ai_hotspot_radar
DATABASE_INIT_RETRIES=10
DATABASE_INIT_RETRY_SECONDS=1

# Redis（可选）：本机 Homebrew Redis 地址；本阶段默认不依赖生产级缓存/队列，但可用于本地演练
REDIS_URL=redis://localhost:6379/0

# AI model provider
# 可选：填写后启用模型查询扩展与热点分析；留空则使用本地降级逻辑
# OPENAI_API_KEY=<填写 OpenAI 兼容模型 API Key>
OPENAI_API_KEY=
# OPENAI_BASE_URL=<填写 OpenAI 兼容接口地址，例如 https://api.openai.com/v1>
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=<填写模型名称，例如 gpt-4o-mini>
OPENAI_MODEL=
RELEVANCE_THRESHOLD=50
SOURCE_FETCH_LIMIT=20
RATE_LIMIT_PER_MINUTE=120

# Optional X/Twitter source
# 可选：填写后启用官方 X API v2 Recent Search；留空则跳过 X/Twitter 来源
# X_API_BEARER_TOKEN=<填写 X API Bearer Token>
X_API_BEARER_TOKEN=

# Optional Bing source
# 可选：填写后启用 Bing Search；留空则跳过 Bing 来源
# BING_SEARCH_API_KEY=<填写 Bing Search API Key>
BING_SEARCH_API_KEY=

# SMTP email
# 可选：填写后启用事件邮件和报告邮件；留空则记录 skipped
# SMTP_HOST=<填写 SMTP 服务器地址，例如 smtp.example.com>
SMTP_HOST=
SMTP_PORT=587
# SMTP_USERNAME=<填写 SMTP 用户名>
SMTP_USERNAME=
# SMTP_PASSWORD=<填写 SMTP 密码或应用专用密码>
SMTP_PASSWORD=
# SMTP_FROM_EMAIL=<填写发件邮箱>
SMTP_FROM_EMAIL=
# SMTP_TO_EMAIL=<填写收件邮箱>
SMTP_TO_EMAIL=
SMTP_USE_TLS=true

# Scheduler
SCHEDULER_ENABLED=false
CHECK_INTERVAL_MINUTES=60
DAILY_REPORT_ENABLED=false
DAILY_REPORT_HOUR=8
WEEKLY_REPORT_ENABLED=false
WEEKLY_REPORT_WEEKDAY=1
WEEKLY_REPORT_HOUR=8

# Web（空表示同源 /api，生产环境与 Nginx 场景建议设为 "/"）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# GitHub 登录（OAuth）
# 必填：请在 GitHub OAuth App 中创建应用并写入以下配置
GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=<填入 GitHub 应用 Secret>
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
# 本地 / 单机部署默认回调/登录页基地址
WEB_BASE_URL=http://localhost:3000

# JWT 会话
JWT_SECRET_KEY=change-me-dev-secret-key
JWT_SESSION_EXPIRE_DAYS=7
