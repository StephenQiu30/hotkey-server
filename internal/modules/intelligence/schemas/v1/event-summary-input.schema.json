{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event-summary-input-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "event_key", "evidence"],
  "properties": {
    "event_id": {"type": "integer", "minimum": 1},
    "event_key": {"type": "string", "minLength": 1, "maxLength": 128},
    "evidence": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["content_id", "locator", "excerpt"],
        "properties": {
          "content_id": {"type": "integer", "minimum": 1},
          "locator": {"type": "string", "minLength": 1, "maxLength": 512},
          "excerpt": {"type": "string", "minLength": 1, "maxLength": 500}
        }
      }
    }
  }
}
