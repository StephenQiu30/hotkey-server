{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event-summary-output-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["title_zh", "sentences"],
  "properties": {
    "title_zh": {"type": "string", "minLength": 1, "maxLength": 500},
    "title_en": {"type": "string", "maxLength": 500},
    "sentences": {
      "type": "array", "maxItems": 32,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["text", "evidence"],
        "properties": {
          "text": {"type": "string", "minLength": 1, "maxLength": 2000},
          "evidence": {
            "type": "array", "minItems": 1, "maxItems": 16,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["content_id", "locator"],
              "properties": {
                "content_id": {"type": "integer", "minimum": 1},
                "locator": {"type": "string", "minLength": 1, "maxLength": 512},
                "excerpt": {"type": "string", "maxLength": 500}
              }
            }
          }
        }
      }
    }
  }
}
