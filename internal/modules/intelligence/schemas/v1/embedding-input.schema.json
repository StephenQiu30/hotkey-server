{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "embedding-input-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["inputs", "language"],
  "properties": {
    "inputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 12000 }
    },
    "language": { "type": "string", "enum": ["zh", "en", "und"] }
  }
}
