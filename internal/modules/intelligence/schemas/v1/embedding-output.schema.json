{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "embedding-output-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["model_version", "vectors"],
  "properties": {
    "model_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "vectors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "array",
        "minItems": 1024,
        "maxItems": 1024,
        "items": { "type": "number" }
      }
    }
  }
}
