{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entity-claim-output-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["entities", "claims"],
  "properties": {
    "entities": {
      "type": "array", "maxItems": 64,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["entity_key", "entity_type", "canonical_name"],
        "properties": {
          "entity_key": {"type": "string", "minLength": 1, "maxLength": 128},
          "entity_type": {"type": "string", "enum": ["person", "organization", "product", "location", "policy", "event", "other"]},
          "canonical_name": {"type": "string", "minLength": 1, "maxLength": 255}
        }
      }
    },
    "claims": {
      "type": "array", "maxItems": 64,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["claim", "evidence"],
        "properties": {
          "claim": {"type": "string", "minLength": 1, "maxLength": 2000},
          "evidence": {
            "type": "array", "minItems": 1, "maxItems": 16,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["content_id", "locator"],
              "properties": {
                "content_id": {"type": "integer", "minimum": 1},
                "locator": {"type": "string", "minLength": 1, "maxLength": 512},
                "excerpt": {"type": "string", "maxLength": 500},
                "stance": {"type": "string", "enum": ["supports", "contradicts", "mentions"]},
                "confidence": {"type": "number", "minimum": 0, "maximum": 100}
              }
            }
          }
        }
      }
    }
  }
}
