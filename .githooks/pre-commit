#!/usr/bin/env bash
# pre-commit — Gate commits with required CI steps.
#
# Runs before every commit. If any step fails the commit is aborted.
# Steps that need external services (DB, Redis, Kafka) are excluded;
# they run in CI via `make ci`.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PASS=0
FAIL=0

pass()  { PASS=$((PASS+1)); echo "  ✓ $1"; }
fail()  { FAIL=$((FAIL+1)); echo "  ✗ $1"; }

echo "=== Pre-commit checks ==="
echo ""

# ---------------------------------------------------------------------------
# 1. Lint
# ---------------------------------------------------------------------------
echo "--- go vet ---"
if go vet ./... 2>&1; then
  pass "go vet"
else
  fail "go vet — fix vet errors before committing"
fi

# ---------------------------------------------------------------------------
# 2. Build
# ---------------------------------------------------------------------------
echo "--- go build ---"
if go build -o /dev/null ./cmd/hotkey 2>&1; then
  pass "build"
else
  fail "build — compilation error"
fi

# ---------------------------------------------------------------------------
# 3. Unit tests (no external services required)
# ---------------------------------------------------------------------------
echo "--- go test (internal + unit) ---"
if go test ./internal/... ./tests/unit/... -count=1 2>&1; then
  pass "unit tests"
else
  fail "unit tests — test failure(s)"
fi

# ---------------------------------------------------------------------------
# 4. Architecture boundaries
# ---------------------------------------------------------------------------
echo "--- validate-arch ---"
if bash scripts/validate-architecture-boundaries.sh 2>&1; then
  pass "architecture boundaries"
else
  fail "architecture boundaries — layer violation"
fi

# ---------------------------------------------------------------------------
# 5. Schema validation (static — only checks db/schema.sql)
# ---------------------------------------------------------------------------
echo "--- validate-schema ---"
if bash scripts/validate-schema.sh 2>&1; then
  pass "schema validation"
else
  fail "schema validation"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo "=== Results: ${PASS} passed, ${FAIL} failed ==="

if [ "$FAIL" -gt 0 ]; then
  echo "❌ Commit blocked — fix failures above and try again."
  exit 1
fi

echo "✅ Commit allowed."
